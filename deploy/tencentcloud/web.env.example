# SQLite database persisted by the docker volume.
DATABASE_URL=file:/app/data/web.db

# Must be your public billing domain.
NEXTAUTH_URL=https://billing.example.com
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Shared secret used by gateway -> web credit deduction.
BILLING_API_KEY=replace-with-billing-secret

# Shared secret used by web -> gateway internal API calls.
GATEWAY_INTERNAL_API_KEY=replace-with-gateway-internal-secret

# Internal docker network address. Do not change unless you rename the compose service.
GATEWAY_INTERNAL_URL=http://gateway:8080

# Optional admin emails for /admin pages.
ADMIN_EMAILS=admin@example.com

# Optional payment QR images.
NEXT_PUBLIC_ALIPAY_QR_URL=https://example.com/alipay-qr.png
NEXT_PUBLIC_WECHAT_QR_URL=https://example.com/wechat-qr.png

# Preferred payment route: ZPAY
ZPAY_PID=
ZPAY_KEY=
ZPAY_GATEWAY=https://zpayz.cn
# Optional sub-channel id when your provider gives you one.
ZPAY_CID=
# Public URLs used by ZPAY server-side callbacks and return redirects.
ZPAY_NOTIFY_URL=https://billing.example.com/api/webhooks/zpay
ZPAY_RETURN_URL=https://billing.example.com/pay/zpay-return

# Optional New API sync.
NEW_API_URL=
NEW_API_ADMIN_TOKEN=

# Optional Alipay direct integration.
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://billing.example.com/api/webhooks/alipay
ALIPAY_RETURN_URL=https://billing.example.com/success

# Optional Stripe support.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_5=
STRIPE_PRICE_10=
STRIPE_PRICE_20=
STRIPE_PRICE_TEST_1C=
