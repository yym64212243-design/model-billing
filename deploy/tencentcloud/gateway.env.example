# SQLite database persisted by the docker volume.
DATABASE_URL=file:/data/gateway.db?mode=rwc
LISTEN_ADDR=:8080

# Either set UPSTREAM_OPENAI_API_KEY or configure CHANNELS_JSON.
UPSTREAM_OPENAI_API_KEY=

# Optional upstream base URL. Keep the default unless you are targeting
# another OpenAI-compatible upstream gateway.
# UPSTREAM_OPENAI_BASE=https://api.openai.com

# Example:
# CHANNELS_JSON=[{"name":"gemini","base_url":"https://generativelanguage.googleapis.com/v1beta/openai","api_keys":["YOUR_GOOGLE_AI_KEY"],"models":["gemini-*"],"priority":10,"format":"gemini"},{"name":"openai","base_url":"https://api.openai.com","api_keys":["sk-..."],"models":["*"],"priority":0,"format":"openai"}]

# Internal docker network address for the web container.
BILLING_BASE_URL=http://web:3000
BILLING_API_KEY=replace-with-billing-secret
GATEWAY_INTERNAL_API_KEY=replace-with-gateway-internal-secret

# Optional billing behavior.
BILLING_DEDUCT_AMOUNT=1
BILLING_TIMEOUT_SEC=10
BILLING_STRICT=false

# Optional static client tokens in addition to database-backed keys.
GATEWAY_API_KEYS=

# Optional rate limiting.
RATE_LIMIT_RPM=300
RATE_LIMIT_WINDOW_SEC=60

# Optional /admin browser page token on the gateway itself.
ADMIN_TOKEN=replace-with-admin-token
