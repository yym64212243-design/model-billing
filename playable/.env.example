# 可选：AI 优化编配（OpenAI 或兼容接口）
# 配置后，生成钢琴谱时会先用 aubio 分析音频，再用 AI 优化音符序列
OPENAI_API_KEY=sk-xxx
# 可选，默认 https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# 可选，默认 gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# 可选：若使用其他兼容 OpenAI 的 API，也可用
# PLAYABLE_AI_API_KEY=your-api-key

# 可选：转谱脚本使用的 Python 解释器
# PLAYABLE_PYTHON=python3
