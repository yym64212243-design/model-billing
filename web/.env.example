# Database (SQLite)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
BILLING_BASE_URL="http://localhost:3000"

# Alipay (primary payment flow)
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_GATEWAY="https://openapi.alipaydev.com/gateway.do"
ALIPAY_NOTIFY_URL="http://localhost:3000/api/webhooks/alipay"
# Optional override for Alipay return_url. If empty, app builds /success?order=...
# ALIPAY_RETURN_URL="http://localhost:3000/success"

# Manual QR payment
# Comma-separated admin emails who can confirm payments
ADMIN_EMAILS="admin@example.com"

# Public QR image URLs (shown on /pay/manual)
# You can host them anywhere or use your own CDN.
NEXT_PUBLIC_ALIPAY_QR_URL="https://example.com/alipay-qr.png"
NEXT_PUBLIC_WECHAT_QR_URL="https://example.com/wechat-qr.png"

# (Legacy) Stripe - not used when using manual payments
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
